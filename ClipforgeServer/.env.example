CLIPFORGE_BASE_URL=http://127.0.0.1:8000
CLIPFORGE_UPLOAD_DIR=uploads
CLIPFORGE_API_TOKEN=replace-me
CLIPFORGE_MAX_UPLOAD_MB=10
CLIPFORGE_UPLOAD_RATE_LIMIT_PER_MINUTE=60
CLIPFORGE_CORS_ALLOW_ORIGINS=
CLIPFORGE_ENABLE_SHARE_EMBEDS=false
CLIPFORGE_EMBED_TITLE_TEMPLATE=Clipforge Upload {basename}
CLIPFORGE_EMBED_DESCRIPTION_TEMPLATE=Shared via Clipforge
CLIPFORGE_EMBED_SITE_NAME=Clipforge
CLIPFORGE_EMBED_THEME_COLOR=#10141c
CLIPFORGE_PUBLIC_LINK_MODE=public
CLIPFORGE_SIGNING_SECRET=
CLIPFORGE_LINK_EXPIRY_SECONDS=86400
CLIPFORGE_IMAGE_OUTPUT_MODE=original
CLIPFORGE_IMAGE_MAX_DIMENSION=0
CLIPFORGE_IMAGE_JPEG_QUALITY=88
CLIPFORGE_IMAGE_WEBP_QUALITY=84
CLIPFORGE_STORAGE_BACKEND=local
CLIPFORGE_S3_BUCKET=
CLIPFORGE_S3_REGION=
CLIPFORGE_S3_ENDPOINT_URL=
CLIPFORGE_S3_ACCESS_KEY_ID=
CLIPFORGE_S3_SECRET_ACCESS_KEY=
CLIPFORGE_S3_PREFIX=
CLIPFORGE_S3_FORCE_PATH_STYLE=false
